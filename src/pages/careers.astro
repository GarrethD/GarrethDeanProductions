---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Careers | Garreth Dean Production"
  description="Careers page for Garreth Dean Production, outlining studio values, working style, and how opportunities will be presented."
  path="/careers"
>
  <section class="page-hero page-hero--compact">
    <p class="section-label">Careers</p>
    <h1>Careers.</h1>
    <p>
      There are no open roles at the moment, but this page is where studio opportunities will be posted.
    </p>
  </section>

  <section class="grid-panel">
    <article class="panel panel--statement">
      <p class="section-label">Working Style</p>
      <h2>What matters here.</h2>
      <ul class="sharp-list">
        <li>Strong craft and clear communication</li>
        <li>Work tied directly to active projects</li>
        <li>Ownership and reliability</li>
        <li>Portfolio-led review when roles open</li>
      </ul>
    </article>

    <article class="panel panel--statement panel--image">
      <img src="/assets/images/JackFullBody.png" alt="Character artwork" />
    </article>
  </section>

  <section class="panel panel--statement">
    <p class="section-label">Current Position</p>
    <h2>No open roles right now.</h2>
    <p>
      The current focus is on the games, the site, and the broader studio presentation. When roles open, they will be listed here.
    </p>
  </section>
</BaseLayout>

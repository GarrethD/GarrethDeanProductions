---
import BaseLayout from "../layouts/BaseLayout.astro";
import { newsItems } from "../data/site";
---

<BaseLayout
  title="News | Garreth Dean Production"
  description="Studio updates, milestones, announcements, and production momentum from Garreth Dean Production."
  path="/news"
>
  <section class="page-hero page-hero--compact">
    <p class="section-label">News</p>
    <h1>Studio updates.</h1>
    <p>
      This page is for project updates, new footage, release milestones, and studio news.
    </p>
  </section>

  <section class="news-grid news-grid--full">
    {
      newsItems.map((item) => (
        <article class="panel panel--news">
          <p class="section-label">{item.date}</p>
          <h2>{item.title}</h2>
          <p>{item.summary}</p>
        </article>
      ))
    }
  </section>

  <section class="grid-panel">
    <article class="panel panel--statement">
      <p class="section-label">What Belongs Here</p>
      <h2>Keep updates useful.</h2>
      <p>
        News should show progress, explain what changed, and give people a reason to come back without turning every post into marketing copy.
      </p>
    </article>

    <article class="panel panel--statement">
      <p class="section-label">Best Update Types</p>
      <ul class="sharp-list">
        <li>New screenshots, clips, and trailer beats</li>
        <li>Store page milestones and public events</li>
        <li>Production progress and feature callouts</li>
        <li>Studio announcements and partnership news</li>
      </ul>
    </article>
  </section>
</BaseLayout>

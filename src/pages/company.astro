---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Company | Garreth Dean Production"
  description="Company overview for Garreth Dean Production, including studio identity, vision, and current operating direction."
  path="/company"
>
  <section class="page-hero page-hero--compact">
    <p class="section-label">Company</p>
    <h1>About the studio.</h1>
    <p>
      Garreth Dean Production is the studio name used across the site, trailers, press materials, and project pages.
    </p>
  </section>

  <section class="section-grid">
    <article class="panel panel--statement">
      <p class="section-label">Creative Positioning</p>
      <h2>What the studio makes.</h2>
      <p>
        The focus is on story-driven games, strong atmosphere, memorable visual identity, and a cleaner public presentation for every release.
      </p>
    </article>

    <article class="panel panel--statement panel--image">
      <img src="/assets/images/Jack.jpg" alt="Studio character artwork" />
    </article>
  </section>

  <section class="grid-panel">
    <article class="panel panel--statement">
      <p class="section-label">What Changed</p>
      <ul class="sharp-list">
        <li>A clearer studio name</li>
        <li>A cleaner site structure</li>
        <li>Better consistency across press, social, and project pages</li>
        <li>A stronger home for updates and merchandise</li>
      </ul>
    </article>

    <article class="panel panel--statement">
      <p class="section-label">Operating Direction</p>
      <h2>Focused work, clear presentation.</h2>
      <p>
        The studio is small, but the goal is to present the work clearly and professionally to players, press, collaborators, and partners.
      </p>
    </article>
  </section>
</BaseLayout>

---
import { navItems } from "../data/site";

const { currentPath } = Astro.props;
---

<header class="site-header">
  <a href="/" class="brand">
    <span class="brand__kicker">Garreth Dean</span>
    <span class="brand__name">Production</span>
  </a>

  <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav">
    <span></span>
    <span></span>
  </button>

  <nav id="site-nav" class="site-nav" aria-label="Primary">
    {
      navItems.map((item) => (
        <a href={item.href} class={currentPath === item.href ? "is-active" : undefined}>
          {item.label}
        </a>
      ))
    }
  </nav>
</header>
